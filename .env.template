# FastAPI settings
DEBUG=false

# Database URL (required, must use postgresql+asyncpg)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>

# Redis URL (required, must use redis:// or rediss://)
REDIS_URL=redis://localhost:6379/0

# JWT secrets (required, each at least 32 characters)
ACCESS_SECRET=change_me_access_secret_at_least_32_chars
REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars

# Token lifetime in minutes
ACCESS_TOKEN_EXPIRE_M=15
REFRESH_TOKEN_EXPIRE_M=43200

# Cookie settings
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
